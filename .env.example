# Wasden Watch Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git — it contains secrets

# === REQUIRED ===
TRADING_MODE=paper                    # "paper" or "live" — system halts if unset
USE_MOCK_DATA=true                    # Set to "false" to use real Supabase data

# === DATABASE (Supabase) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here       # Bypasses RLS — keep secret

# === FRONTEND ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_API_URL=http://localhost:8000

# === API SECURITY ===
API_KEY=                              # Set to enable API key auth (leave empty to disable)

# === TRADING (Alpaca) ===
ALPACA_PAPER_API_KEY=                 # Paper trading API key
ALPACA_PAPER_SECRET_KEY=              # Paper trading secret
ALPACA_LIVE_API_KEY=                  # Live trading — handle with extreme care
ALPACA_LIVE_SECRET_KEY=               # Live trading — handle with extreme care

# === DATA PROVIDERS ===
FINNHUB_API_KEY=                      # Finnhub market data
NEWSAPI_KEY=                          # NewsAPI headlines

# === NOTIFICATIONS (optional — all channels disabled by default) ===
SLACK_WEBHOOK_URL=                    # Slack incoming webhook URL
SMTP_HOST=                            # SMTP server hostname
SMTP_PORT=587                         # SMTP port (default 587)
SMTP_USER=                            # SMTP username
SMTP_PASSWORD=                        # SMTP password — keep secret
NOTIFICATION_EMAIL_RECIPIENTS=        # Comma-separated email addresses

# === MLFLOW (optional — local file store by default) ===
MLFLOW_TRACKING_URI=mlruns            # MLflow tracking URI (default: local mlruns/)
MLFLOW_EXPERIMENT_NAME=wasden-watch-quant  # MLflow experiment name
